{
  "compilerOptions": {
    // Compile TypeScript down to ES2020 syntax. Safe default for Node.js — supported
    // by all modern Node versions without compatibility issues.
    "target": "ES2020",

    // Use ESM module system (import/export), consistent with the client.
    // Requires "type": "module" in package.json.
    "module": "NodeNext",

    // Tells TypeScript how to resolve modules, must match "module" setting.
    "moduleResolution": "NodeNext",

    // Source TypeScript files live in src/
    "rootDir": "./src",

    // Compiled JavaScript output goes to dist/
    "outDir": "./dist",

    // Enable all strict type checks. Catches more bugs at compile time.
    "strict": true,

    // Allows default imports from CommonJS modules that don't have a default export.
    "esModuleInterop": true,

    // Skip type checking of declaration files in node_modules. Speeds up compilation.
    "skipLibCheck": true,

    // Ensures imports are case-sensitive across all operating systems.
    // Prevents bugs that only appear on Linux but not Mac.
    "forceConsistentCasingInFileNames": true,

    // Allows importing JSON files directly in TypeScript.
    "resolveJsonModule": true,

    // Generates source maps so debuggers can map compiled JS back to original TS.
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
